# Local development only. The production API URL is discovered through /api/runtime.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# AWS Cognito managed login / OAuth 2.0 authorization-code flow with PKCE.
VITE_COGNITO_DOMAIN=https://example.auth.us-east-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=replace-me
VITE_COGNITO_SCOPE=openid profile email

# Published only after the repository and verified recording exist.
VITE_GITHUB_REPOSITORY_URL=
VITE_DEMO_RECORDING_URL=

# Vercel serverless only. Never expose this as a VITE_ variable.
EDGE_CONFIG=
